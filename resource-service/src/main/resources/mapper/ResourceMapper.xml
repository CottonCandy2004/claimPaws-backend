<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.czu.claimpaws.resource.persistence.ResourceMapper">

    <resultMap id="resourceResultMap" type="cn.czu.claimpaws.resource.domain.Resource">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="name" javaType="java.lang.String"/>
            <arg column="type" javaType="java.lang.String"/>
            <arg column="floor" javaType="java.lang.String"/>
            <arg column="building" javaType="java.lang.String"/>
            <arg column="capacity" javaType="java.lang.Integer"/>
            <arg column="description" javaType="java.lang.String"/>
            <arg column="active" javaType="java.lang.Boolean"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
            <arg column="deleted" javaType="java.lang.Boolean"/>
        </constructor>
    </resultMap>

    <select id="requireActive" resultMap="resourceResultMap">
        SELECT * FROM resources
        WHERE id = #{id} AND active = TRUE AND deleted = FALSE
    </select>

</mapper>
