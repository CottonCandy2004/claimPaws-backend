<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.czu.claimpaws.identity.persistence.UserMapper">

    <resultMap id="userResultMap" type="cn.czu.claimpaws.identity.domain.User">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="username" javaType="java.lang.String"/>
            <arg column="password_hash" javaType="java.lang.String"/>
            <arg column="display_name" javaType="java.lang.String"/>
            <arg column="email" javaType="java.lang.String"/>
            <arg column="phone" javaType="java.lang.String"/>
            <arg column="department_id" javaType="java.lang.Long"/>
            <arg column="enabled" javaType="java.lang.Boolean"/>
            <arg column="created_at" javaType="java.time.LocalDateTime"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
            <arg column="deleted" javaType="java.lang.Boolean"/>
        </constructor>
    </resultMap>

    <select id="requireActive" resultMap="userResultMap">
        SELECT * FROM users
        WHERE id = #{id} AND enabled = TRUE AND deleted = FALSE
    </select>

    <select id="findByUsername" resultMap="userResultMap">
        SELECT * FROM users
        WHERE username = #{username} AND deleted = FALSE
    </select>

    <insert id="insert" useGeneratedKeys="true" keyColumn="id">
        INSERT INTO users (username, password_hash, display_name, email, phone, department_id, enabled, created_at, updated_at)
        VALUES (#{username}, #{passwordHash}, #{displayName}, #{email}, #{phone}, #{departmentId}, #{enabled}, NOW(), NOW())
    </insert>

</mapper>
