<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.czu.claimpaws.notification.persistence.ConsumedEventMapper">

    <select id="countByEventId" resultType="long">
        SELECT COUNT(1) FROM consumed_events WHERE event_id = #{eventId}
    </select>

    <insert id="insert">
        INSERT INTO consumed_events(event_id) VALUES(#{eventId})
    </insert>
</mapper>
